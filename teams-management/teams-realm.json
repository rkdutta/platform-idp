        "http://engineering-platform.local",
        "http://localhost:4200",
        "http://localhost:4201",
        "http://rdutta.coder:4200"
      ],
      "publicClient": true,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://platform-auth.127.0.0.1.sslip.io/*##http://localhost:4200/*##http://localhost:4201/*##http://rdutta.coder:*"
